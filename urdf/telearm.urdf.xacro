<?xml version="1.0"?>
<robot name="robot" xmlns:xacro="http://ros.org/wiki/xacro">

   <link name="body">
    <inertial>
      <mass value="1"/>
      <inertia ixx=".1" ixy="0" ixz="0" iyy=".1" iyz="0" izz=".1" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="file://$(find TeleARM)/meshes/body.STL" scale="1 1 1"/>
      </geometry>
      <material name="red">
        <color rgba="1 0 0 1"/> <!-- Black color -->
      </material>
    </visual>
  </link>

  <link name="window">
    <inertial>
      <mass value="1"/>
      <inertia ixx=".1" ixy="0" ixz="0" iyy=".1" iyz="0" izz=".1" />
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="file://$(find TeleARM)/meshes/window.STL" scale="1 1 1"/>
      </geometry>
      <material name="red">
        <color rgba="1 0 0 1"/> <!-- Black color -->
      </material>
    </visual>
  </link>
  <!-- Front Left -->
  <link name="front_left_wheel">
    <inertial>
      <mass value="1"/>
      <inertia ixx=".1" ixy="0" ixz="0" iyy=".1" iyz="0" izz=".1" />
    </inertial>
    <collision>
      <origin xyz="0 0 0.16" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.4175" length=".16"/>
      </geometry>
    </collision>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="file://$(find TeleARM)/meshes/wheel.STL" scale="1 1 1"/>
      </geometry>
      <material name="black">
        <color rgba="0 0 0 1"/> <!-- Black color -->
      </material>
    </visual>
  </link>
  <!-- Front Right -->
  <link name="front_right_wheel">
    <inertial>
      <mass value="1"/>
      <inertia ixx=".1" ixy="0" ixz="0" iyy=".1" iyz="0" izz=".1" />
    </inertial>
    <collision>
      <origin xyz="0 0 0.16" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.4175" length=".16"/>
      </geometry>
    </collision>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="file://$(find TeleARM)/meshes/wheel.STL" scale="1 1 1"/>
      </geometry>
      <material name="black">
        <color rgba="0 0 0 1"/> <!-- Black color -->
      </material>
    </visual>
  </link>
  <!-- Back Left -->
  <link name="back_left_wheel">
    <inertial>
      <mass value="1"/>
      <inertia ixx=".1" ixy="0" ixz="0" iyy=".1" iyz="0" izz=".1" />
    </inertial>
    <collision>
      <origin xyz="0 0 0.16" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.4175" length=".16"/>
      </geometry>
    </collision>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="file://$(find TeleARM)/meshes/wheel.STL" scale="1 1 1"/>
      </geometry>
      <material name="black">
        <color rgba="0 0 0 1"/> <!-- Black color -->
      </material>
    </visual>
  </link>
  <!-- Back Right -->
  <link name="back_right_wheel">
    <inertial>
      <mass value="1"/>
      <inertia ixx=".1" ixy="0" ixz="0" iyy=".1" iyz="0" izz=".1" />
    </inertial>
    <collision>
      <origin xyz="0 0 0.16" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.4175" length=".16"/>
      </geometry>
    </collision>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="file://$(find TeleARM)/meshes/wheel.STL" scale="1 1 1"/>
      </geometry>
      <material name="black">
        <color rgba="0 0 0 1"/> <!-- Black color -->
      </material>
    </visual>
  </link>

  <joint name="body_to_window" type="fixed">
    <origin xyz="0 0 0"/>
    <parent link="body"/>
    <child link="window"/>
  </joint>

  <joint name="body_to_front_left_wheel" type="continuous">
    <origin xyz="1.505428 0.573211 0.055848" rpy="${-pi/2} 0 0"/>
    <parent link="body"/>
    <child link="front_left_wheel"/>
    <axis xyz="0 0 1"/>
  </joint>

  <joint name="body_to_front_right_wheel" type="continuous">
    <origin xyz="1.505428 -0.573211 0.055848" rpy="${pi/2} 0 0"/>
    <parent link="body"/>
    <child link="front_right_wheel"/>
    <axis xyz="0 0 -1"/>
  </joint>

  <joint name="body_to_back_left_wheel" type="continuous">
    <origin xyz="-1.505428 0.573211 0.055848" rpy="${-pi/2} 0 0"/>
    <parent link="body"/>
    <child link="back_left_wheel"/>
    <axis xyz="0 0 1"/>
  </joint>

  <joint name="body_to_back_right_wheel" type="continuous">
    <origin xyz="-1.505428 -0.573211 0.055848" rpy="${pi/2} 0 0"/>
    <parent link="body"/>
    <child link="back_right_wheel"/>
    <axis xyz="0 0 -1"/>
  </joint>

  <link name="lidar_link"/>
  <joint name="body_to_lidar_link" type="fixed">
    <!-- Front license-plate area (body mesh: x front~2.19, z roof~1.18, z bottom~0) -->
    <origin xyz="2.1 0 0.9" rpy="0 0 0"/>
    <parent link="body"/>
    <child link="lidar_link"/>
  </joint>

  <ros2_control name="GazeboSystem" type="system">
    <hardware>
      <plugin>gazebo_ros2_control/GazeboSystem</plugin>
    </hardware>
    <joint name="body_to_back_left_wheel"> 
      <command_interface name="velocity">
        <param name="min">-1</param>
        <param name="max">1</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="body_to_back_right_wheel">
      <command_interface name="velocity">
        <param name="min">-1</param>
        <param name="max">1</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

  <gazebo>
    <!-- Joint state publisher -->
    <plugin filename="libgazebo_ros2_control.so" name="gazebo_ros2_control">
      <parameters>$(find TeleARM)/config/diff_drive_controller.yaml</parameters>
    </plugin>
  </gazebo>

  <gazebo reference="body">
    <material>Gazebo/Red</material>
  </gazebo>
  <gazebo reference="window">
    <material>Gazebo/Black</material>
  </gazebo>
  <gazebo reference="front_left_wheel">
    <material>Gazebo/Black</material>
    <mu1 value="0.0"/>
    <mu2 value="0.0"/>
  </gazebo>
  <gazebo reference="front_right_wheel">
    <material>Gazebo/Black</material>
    <mu1 value="0.0"/>
    <mu2 value="0.0"/>
  </gazebo>
  <gazebo reference="back_left_wheel">
    <material>Gazebo/Black</material>
  </gazebo>
  <gazebo reference="back_right_wheel">
    <material>Gazebo/Black</material>
  </gazebo>

  <gazebo reference="lidar_link">
    <sensor type="ray" name="lidar_sensor">
      <pose>0 0 0 0 0 0</pose>
      <visualize>true</visualize>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>720</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.12</min>
          <max>12.0</max>
          <resolution>0.01</resolution>
        </range>
      </ray>
      <plugin name="lidar" filename="libgazebo_ros_ray_sensor.so">
        <output_type>sensor_msgs/LaserScan</output_type>
        <frame_name>lidar_link</frame_name>
        <ros>
          <remapping>~/out:=scan</remapping>
        </ros>
      </plugin>
    </sensor>
  </gazebo>

</robot>